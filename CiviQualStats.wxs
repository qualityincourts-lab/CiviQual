<?xml version="1.0" encoding="UTF-8"?>
<!--
  CiviQual Stats — WiX 5.0 installer source.

  A single WiX project produces either a per-user or a per-machine MSI by
  changing the InstallScope parameter on the MSBuild command line or by
  editing the three lines flagged with "SCOPE" below.

  Build commands (run from this directory):
    Per-user:    wix build CiviQualStats.wxs -d Scope=perUser    -o CiviQualStats_PerUser.msi
    Per-machine: wix build CiviQualStats.wxs -d Scope=perMachine -o CiviQualStats_PerMachine.msi

  The two variants differ in:
    * InstallScope            (perUser | perMachine)
    * InstallFolder directory (LocalAppDataFolder | ProgramFiles64Folder)
    * Package name suffix
-->

<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <?define ProductName = "CiviQual Stats" ?>
  <?define ProductVersion = "2.0.0" ?>
  <?define Manufacturer = "A Step in the Right Direction, LLC" ?>
  <?define UpgradeCode = "C4A83E22-63B1-4D27-9C70-0E3F6C1A5B11" ?>

  <!-- Variables driven by the Scope build parameter -->
  <?if $(Scope)=perMachine?>
    <?define InstallScopeValue = "perMachine" ?>
    <?define InstallFolderRef  = "ProgramFiles64Folder" ?>
    <?define PackageSuffix     = " (Per-Machine)" ?>
  <?else?>
    <?define InstallScopeValue = "perUser" ?>
    <?define InstallFolderRef  = "LocalAppDataFolder" ?>
    <?define PackageSuffix     = " (Per-User)" ?>
  <?endif?>

  <Package Name="$(ProductName)$(PackageSuffix)"
           Manufacturer="$(Manufacturer)"
           Version="$(ProductVersion)"
           UpgradeCode="$(UpgradeCode)"
           InstallerVersion="500"
           Scope="$(InstallScopeValue)"
           Compressed="yes">

    <SummaryInformation Description="$(ProductName) v$(ProductVersion) Installer" />
    <MajorUpgrade DowngradeErrorMessage="A newer version of $(ProductName) is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <!-- Features: Core is required, Pro is optional and unlocks via license -->
    <Feature Id="FeatureCore"
             Title="$(ProductName) Core"
             Level="1"
             AllowAbsent="no"
             Display="expand">
      <ComponentGroupRef Id="CoreComponents" />
      <ComponentGroupRef Id="DocsComponents" />
      <ComponentGroupRef Id="SamplesComponents" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>

    <Feature Id="FeaturePro"
             Title="Pro Module Files"
             Level="1"
             Display="expand"
             Description="Install the Pro statistical modules. A valid Pro license file is still required to use them.">
      <ComponentGroupRef Id="ProComponents" />
    </Feature>

    <StandardDirectory Id="$(InstallFolderRef)">
      <Directory Id="PublisherDir" Name="$(Manufacturer)">
        <Directory Id="InstallFolder" Name="$(ProductName)">
          <Directory Id="DocsFolder" Name="docs" />
          <Directory Id="SamplesFolder" Name="samples" />
        </Directory>
      </Directory>
    </StandardDirectory>

    <!-- Start menu -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="StartMenuProductDir" Name="$(ProductName)" />
    </StandardDirectory>

    <ComponentGroup Id="CoreComponents" Directory="InstallFolder">
      <!-- Python source files; replace with compiled EXE if you move to PyInstaller -->
      <Component Id="cmp_Main">
        <File Id="file_Main" Source="main.py" />
      </Component>
      <Component Id="cmp_Version">
        <File Id="file_Version" Source="version.py" />
      </Component>
      <Component Id="cmp_License">
        <File Id="file_License" Source="license_manager.py" />
      </Component>
      <Component Id="cmp_Data">
        <File Id="file_Data" Source="data_handler.py" />
      </Component>
      <Component Id="cmp_Stats">
        <File Id="file_Stats" Source="statistics_engine.py" />
      </Component>
      <Component Id="cmp_Viz">
        <File Id="file_Viz" Source="visualizations.py" />
      </Component>
      <Component Id="cmp_Proc">
        <File Id="file_Proc" Source="process_diagrams.py" />
      </Component>
      <Component Id="cmp_Report">
        <File Id="file_Report" Source="report_generator.py" />
      </Component>
      <Component Id="cmp_UICommon">
        <File Id="file_UICommon" Source="ui_common.py" />
      </Component>
      <Component Id="cmp_FreeTools">
        <File Id="file_FreeTools" Source="free_tools.py" />
      </Component>
      <Component Id="cmp_Req">
        <File Id="file_Req" Source="requirements.txt" />
      </Component>
      <Component Id="cmp_Readme">
        <File Id="file_Readme" Source="README.md" />
      </Component>
      <Component Id="cmp_Changelog">
        <File Id="file_Changelog" Source="CHANGELOG.md" />
      </Component>
      <Component Id="cmp_LicenseTxt">
        <File Id="file_LicenseTxt" Source="LICENSE.txt" />
      </Component>
      <Component Id="cmp_Icon">
        <File Id="file_Icon" Source="civiqual_icon.ico" />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="ProComponents" Directory="InstallFolder">
      <Component Id="cmp_MSA"><File Source="msa.py" /></Component>
      <Component Id="cmp_DOE"><File Source="doe.py" /></Component>
      <Component Id="cmp_HT"><File Source="hypothesis_tests.py" /></Component>
      <Component Id="cmp_SS"><File Source="sample_size.py" /></Component>
      <Component Id="cmp_AC"><File Source="advanced_capability.py" /></Component>
      <Component Id="cmp_MR"><File Source="multiple_regression.py" /></Component>
      <Component Id="cmp_ACC"><File Source="advanced_control_charts.py" /></Component>
      <Component Id="cmp_LC"><File Source="lean_calculators.py" /></Component>
      <Component Id="cmp_RCT"><File Source="root_cause_tools.py" /></Component>
      <Component Id="cmp_ST"><File Source="solution_tools.py" /></Component>
      <Component Id="cmp_PT"><File Source="planning_tools.py" /></Component>
      <Component Id="cmp_DT"><File Source="data_tools.py" /></Component>
      <Component Id="cmp_CE"><File Source="chart_editor.py" /></Component>
    </ComponentGroup>

    <ComponentGroup Id="DocsComponents" Directory="DocsFolder">
      <Component Id="cmp_UserGuide">
        <File Id="file_UserGuide" Source="docs/user_guide.html" />
      </Component>
    </ComponentGroup>

    <!-- Samples are harvested dynamically: add new <File> entries here as needed -->
    <ComponentGroup Id="SamplesComponents" Directory="SamplesFolder">
      <Component Id="cmp_SampleReadme">
        <File Id="file_SampleReadme" Source="samples/README.txt" />
      </Component>
    </ComponentGroup>

    <Component Id="StartMenuShortcut" Directory="StartMenuProductDir" Guid="*">
      <Shortcut Id="ShortcutMain"
                Name="$(ProductName)"
                Description="Launch $(ProductName)"
                Target="[#file_Main]"
                WorkingDirectory="InstallFolder"
                Icon="CiviQualIcon" />
      <Shortcut Id="ShortcutGuide"
                Name="$(ProductName) User Guide"
                Description="Open the User Guide"
                Target="[#file_UserGuide]"
                WorkingDirectory="DocsFolder" />
      <RemoveFolder Id="CleanupStartMenu" On="uninstall" />
      <RegistryValue Root="HKCU"
                     Key="Software\$(Manufacturer)\$(ProductName)"
                     Name="installed" Type="integer" Value="1"
                     KeyPath="yes" />
    </Component>

    <Icon Id="CiviQualIcon" SourceFile="civiqual_icon.ico" />
    <Property Id="ARPPRODUCTICON" Value="CiviQualIcon" />
    <Property Id="ARPURLINFOABOUT" Value="https://qualityincourts.com" />
    <Property Id="ARPHELPLINK" Value="https://qualityincourts.com" />

    <ui:WixUI Id="WixUI_FeatureTree" />
    <WixVariable Id="WixUILicenseRtf" Value="installer/License.rtf" />

  </Package>
</Wix>
