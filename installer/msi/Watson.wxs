<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

    <Package Name="WATSON"
             Version="1.3.0.0"
             Manufacturer="A Step in the Right Direction LLC"
             UpgradeCode="{E8F9A1B2-C3D4-5E6F-7A8B-9C0D1E2F3A4B}"
             Scope="perMachine"
             InstallerVersion="500">

        <SummaryInformation Description="WATSON Statistical Analysis Tool"
                           Manufacturer="A Step in the Right Direction LLC" />

        <MajorUpgrade DowngradeErrorMessage="A newer version of WATSON is already installed."
                      AllowSameVersionUpgrades="yes" />

        <MediaTemplate EmbedCab="yes" />

        <Icon Id="WatsonIcon.ico" SourceFile="watson_icon.ico" />
        <Property Id="ARPPRODUCTICON" Value="WatsonIcon.ico" />
        <Property Id="ARPHELPLINK" Value="https://www.qualityincourts.com" />
        <Property Id="ARPURLINFOABOUT" Value="https://www.qualityincourts.com" />

        <WixVariable Id="WixUILicenseRtf" Value="LICENSE.rtf" />

        <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />

        <StandardDirectory Id="ProgramFiles64Folder">
            <Directory Id="INSTALLFOLDER" Name="Watson">
                <Directory Id="SamplesFolder" Name="samples" />
            </Directory>
        </StandardDirectory>

        <StandardDirectory Id="ProgramMenuFolder">
            <Directory Id="WatsonStartMenuFolder" Name="WATSON" />
        </StandardDirectory>

        <StandardDirectory Id="DesktopFolder" />

        <ComponentGroup Id="MainComponents" Directory="INSTALLFOLDER">
            
            <Component Id="MainExecutable" Guid="{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}">
                <File Id="WatsonExe" Source="Files\Watson.exe" KeyPath="yes">
                    <Shortcut Id="StartMenuShortcut"
                              Directory="WatsonStartMenuFolder"
                              Name="WATSON"
                              Description="Statistical Analysis Tool for Lean Six Sigma"
                              WorkingDirectory="INSTALLFOLDER"
                              Icon="WatsonIcon.ico"
                              Advertise="yes" />
                    <Shortcut Id="DesktopShortcut"
                              Directory="DesktopFolder"
                              Name="WATSON"
                              Description="Statistical Analysis Tool for Lean Six Sigma"
                              WorkingDirectory="INSTALLFOLDER"
                              Icon="WatsonIcon.ico"
                              Advertise="yes" />
                </File>
            </Component>

            <Component Id="IconFile" Guid="{B2C3D4E5-F6A7-8901-BCDE-F12345678901}">
                <File Id="WatsonIconPng" Source="Files\watson_icon.png" KeyPath="yes" />
            </Component>

            <Component Id="ReadmeFile" Guid="{E5F6A7B8-C9D0-1234-EF01-23456789ABCD}">
                <File Id="ReadmeMd" Source="Files\README.md" KeyPath="yes" />
            </Component>

            <Component Id="LicenseFile" Guid="{F6A7B8C9-D0E1-2345-F012-3456789ABCDE}">
                <File Id="LicenseTxt" Source="Files\LICENSE" KeyPath="yes" />
            </Component>

            <Component Id="AccessibilityDoc" Guid="{A7B8C9D0-E1F2-3456-0123-456789ABCDEF}">
                <File Id="Section508Md" Source="Files\SECTION_508_COMPLIANCE.md" KeyPath="yes" />
            </Component>

            <Component Id="RegistryEntries" Guid="{D4E5F6A7-B8C9-0123-DEF0-123456789ABC}">
                <RegistryKey Root="HKCU" Key="Software\AStepInTheRightDirection\Watson">
                    <RegistryValue Type="string" Name="InstallPath" Value="[INSTALLFOLDER]" KeyPath="yes" />
                    <RegistryValue Type="string" Name="Version" Value="1.3.0" />
                </RegistryKey>
            </Component>

        </ComponentGroup>
        
        <ComponentGroup Id="SampleDataComponents" Directory="SamplesFolder">
            <Component Id="SampleData" Guid="{C3D4E5F6-A7B8-9012-CDEF-123456789012}">
                <File Id="SampleDataCsv" Source="Files\samples\sample_data.csv" KeyPath="yes" />
            </Component>
            <Component Id="Sample311" Guid="{C3D4E5F6-A7B8-9012-CDEF-123456789013}">
                <File Id="Sample311Csv" Source="Files\samples\sample_311_services.csv" KeyPath="yes" />
            </Component>
            <Component Id="SampleBenefits" Guid="{C3D4E5F6-A7B8-9012-CDEF-123456789014}">
                <File Id="SampleBenefitsCsv" Source="Files\samples\sample_benefits.csv" KeyPath="yes" />
            </Component>
            <Component Id="SampleCitizen" Guid="{C3D4E5F6-A7B8-9012-CDEF-123456789015}">
                <File Id="SampleCitizenCsv" Source="Files\samples\sample_citizen_services.csv" KeyPath="yes" />
            </Component>
            <Component Id="SampleCourtCases" Guid="{C3D4E5F6-A7B8-9012-CDEF-123456789016}">
                <File Id="SampleCourtCasesCsv" Source="Files\samples\sample_court_cases.csv" KeyPath="yes" />
            </Component>
            <Component Id="SampleCourtClerk" Guid="{C3D4E5F6-A7B8-9012-CDEF-123456789017}">
                <File Id="SampleCourtClerkCsv" Source="Files\samples\sample_court_clerk.csv" KeyPath="yes" />
            </Component>
            <Component Id="SampleInspections" Guid="{C3D4E5F6-A7B8-9012-CDEF-123456789018}">
                <File Id="SampleInspectionsCsv" Source="Files\samples\sample_inspections.csv" KeyPath="yes" />
            </Component>
            <Component Id="SampleMail" Guid="{C3D4E5F6-A7B8-9012-CDEF-123456789019}">
                <File Id="SampleMailCsv" Source="Files\samples\sample_mail_processing.csv" KeyPath="yes" />
            </Component>
            <Component Id="SamplePermits" Guid="{C3D4E5F6-A7B8-9012-CDEF-12345678901A}">
                <File Id="SamplePermitsCsv" Source="Files\samples\sample_permits.csv" KeyPath="yes" />
            </Component>
            <Component Id="SampleHealth" Guid="{C3D4E5F6-A7B8-9012-CDEF-12345678901B}">
                <File Id="SampleHealthCsv" Source="Files\samples\sample_public_health.csv" KeyPath="yes" />
            </Component>
            <Component Id="SampleRecords" Guid="{C3D4E5F6-A7B8-9012-CDEF-12345678901C}">
                <File Id="SampleRecordsCsv" Source="Files\samples\sample_public_records.csv" KeyPath="yes" />
            </Component>
        </ComponentGroup>

        <ComponentGroup Id="StartMenuCleanup" Directory="WatsonStartMenuFolder">
            <Component Id="StartMenuFolderRemoval" Guid="{B8C9D0E1-F2A3-4567-1234-56789ABCDEF0}">
                <RemoveFolder Id="RemoveStartMenuFolder" On="uninstall" />
                <RegistryValue Root="HKCU" 
                              Key="Software\AStepInTheRightDirection\Watson\StartMenu" 
                              Type="string" 
                              Value="" 
                              KeyPath="yes" />
            </Component>
        </ComponentGroup>

        <Feature Id="MainFeature" Title="WATSON Application" Level="1" ConfigurableDirectory="INSTALLFOLDER">
            <ComponentGroupRef Id="MainComponents" />
            <ComponentGroupRef Id="SampleDataComponents" />
            <ComponentGroupRef Id="StartMenuCleanup" />
        </Feature>

    </Package>
</Wix>
